{
    "private": true,
    "type": "module",
    "engines": {
        "node": ">=26 <27"
    },
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "docker:dev:build": "docker compose --env-file .env.docker.dev.local -f docker-compose.dev.yml build",
        "docker:dev:key:generate": "docker compose --env-file .env.docker.dev.local -f docker-compose.dev.yml run --rm -T --no-deps app php artisan key:generate --show",
        "docker:dev:up": "docker compose --env-file .env.docker.dev.local -f docker-compose.dev.yml up -d --build",
        "docker:dev:down": "docker compose --env-file .env.docker.dev.local -f docker-compose.dev.yml down --remove-orphans",
        "docker:dev:logs": "docker compose --env-file .env.docker.dev.local -f docker-compose.dev.yml logs -f --tail=200",
        "docker:dev:test:php": "docker compose --env-file .env.docker.dev.local -f docker-compose.dev.yml exec -T app php artisan test",
        "docker:dev:test:vitest": "docker compose --env-file .env.docker.dev.local -f docker-compose.dev.yml exec -T vite npm run test:vitest",
        "test": "vitest run --config vitest.config.js --maxWorkers=1",
        "test:coverage": "vitest run --config vitest.config.js --maxWorkers=1 --coverage",
        "test:e2e": "playwright test",
        "test:e2e:docker": "node tests/e2e/run-playwright-docker.mjs",
        "test:e2e:modal-screenshots:docker": "node tests/e2e/run-playwright-docker.mjs --capture-modal-screenshots tests/e2e/modal-preview.spec.js --project=chromium",
        "test:vitest": "vitest run --config vitest.config.js --maxWorkers=1",
        "docker:dev:test:js": "docker compose --env-file .env.docker.dev.local -f docker-compose.dev.yml exec -T vite npm run test"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.11.3",
        "@playwright/test": "^1.57.0",
        "@tailwindcss/postcss": "^4.3.2",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.3.2",
        "@vitest/coverage-v8": "^4.1.9",
        "autoprefixer": "^10.4.23",
        "chart.js": "^4.5.1",
        "concurrently": "^10.0.3",
        "daisyui": "^5.6.17",
        "jsdom": "^29.1.1",
        "laravel-vite-plugin": "^3.0.1",
        "postcss": "^8.5.17",
        "puppeteer": "^25.3.0",
        "tailwindcss": "^4.3.2",
        "vite": "^8.1.3",
        "vitest": "^4.1.8",
        "zod": "^4.3.5"
    },
    "dependencies": {
        "@alpinejs/anchor": "^3.15.8",
        "@alpinejs/collapse": "^3.15.12",
        "@alpinejs/focus": "^3.15.8",
        "@alpinejs/persist": "^3.15.12",
        "alpinejs": "^3.15.4",
        "leaflet": "^1.9.4",
        "leaflet.markercluster": "^1.5.3",
        "three": "^0.185.1"
    },
    "allowScripts": {
        "unrs-resolver@1.12.2": true,
        "puppeteer@25.3.0": true
    }
}
