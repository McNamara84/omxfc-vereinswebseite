APP_NAME="Offizieller MADDRAX Fanclub e. V."
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_VERSION=0.0.0

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=omxfc_vereinswebseite
DB_USERNAME=root
DB_PASSWORD=

# Database maintenance dump/restore is disabled by default and must be enabled explicitly.
DATABASE_MAINTENANCE_ENABLED=false

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
IMAGE_DRIVER=gd
QUEUE_CONNECTION=database
DB_QUEUE_RETRY_AFTER=420
SCOUT_DRIVER=typesense
SCOUT_QUEUE=false

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

TYPESENSE_API_KEY=xyz
TYPESENSE_HOST=127.0.0.1
TYPESENSE_PORT=8108
TYPESENSE_PATH=
TYPESENSE_PROTOCOL=http
TYPESENSE_MAX_TOTAL_RESULTS=1000

VITE_APP_NAME="${APP_NAME}"

# Trusted Proxies für Rate Limiting & URL-Generierung
# '*' = alle Proxies vertrauen (Standard für Docker-Setup)
# Alternativ: konkrete IPs/Netze kommasepariert, z.B. '172.18.0.0/16,10.0.0.0/8'
TRUSTED_PROXIES=*

# Fantreffen Configuration
# Deadline for T-Shirt orders (format: YYYY-MM-DD HH:MM:SS)
FANTREFFEN_TSHIRT_DEADLINE="2026-02-28 23:59:59"
# Minimale Formular-Ausfüllzeit in Sekunden (Spam-Schutz, Default: 3)
FANTREFFEN_MIN_FORM_TIME=3
# Rate Limiting deaktivieren (nur für Tests, Default: false)
FANTREFFEN_DISABLE_RATE_LIMIT=false

# PayPal Configuration for Fantreffen
PAYPAL_ME_USERNAME=OfficialMaddraxFanclub
PAYPAL_FANTREFFEN_EMAIL=vorstand@maddrax-fanclub.de

# Nextcloud-Galerien fuer die Fotogalerie
NEXTCLOUD_LINK_2026=
NEXTCLOUD_LINK_2025=https://cloud.maddrax-fanclub.de/public.php/dav/files/jnGa6sEecKa3fiX/Foto
NEXTCLOUD_LINK_2024=https://cloud.maddrax-fanclub.de/public.php/dav/files/tztWY5ML5XMRWPw/Foto
NEXTCLOUD_LINK_2023=https://cloud.maddrax-fanclub.de/public.php/dav/files/jjpfnJbgStE8LcQ/Foto

# Maddraxikon OAuth/Baxx integration (feature flags stay false until staged rollout)
MADDRAXIKON_BASE_URL=https://de.maddraxikon.com
MADDRAXIKON_WIKI_KEY=maddraxikon-de
MADDRAXIKON_CONSENT_VERSION=2026-07-18
MADDRAXIKON_IDENTITY_HMAC_PEPPERS=
MADDRAXIKON_OAUTH_CLIENT_ID=
MADDRAXIKON_OAUTH_CLIENT_SECRET=
MADDRAXIKON_OAUTH_REDIRECT_URI=
MADDRAXIKON_OAUTH_SCOPE=mwoauth-authonly
MADDRAXIKON_LINKING_ENABLED=false
MADDRAXIKON_SYNC_ENABLED=false
MADDRAXIKON_AWARDS_ENABLED=false
MADDRAXIKON_USER_AGENT="OMXFC-Vereinswebsite/1.0 (https://maddrax-fanclub.de; info@maddraxikon.com)"
MADDRAXIKON_HTTP_CONNECT_TIMEOUT=5
MADDRAXIKON_HTTP_TIMEOUT=15
MADDRAXIKON_HTTP_ATTEMPTS=3
MADDRAXIKON_HTTP_RETRY_DELAY_MS=500
MADDRAXIKON_HTTP_RETRY_MAX_DELAY_MS=5000
MADDRAXIKON_API_MAXLAG=5
MADDRAXIKON_RECENT_CHANGES_RETENTION_DAYS=30
MADDRAXIKON_SYNC_MAX_WINDOW_MINUTES=360
MADDRAXIKON_RECOVERY_MAX_WINDOW_DAYS=90
MADDRAXIKON_USERCONTRIBS_BATCH_SIZE=50
MADDRAXIKON_EVALUATION_SOURCE_BATCH_SIZE=100
MADDRAXIKON_EVALUATION_API_BATCH_SIZE=50
MADDRAXIKON_MONITOR_PENDING_STALE_HOURS=26
MADDRAXIKON_MONITOR_IMPORT_STALE_MINUTES=60
MADDRAXIKON_MONITOR_SCHEDULER_STALE_MINUTES=5
MADDRAXIKON_MONITOR_QUEUE_BACKLOG_LIMIT=100
MADDRAXIKON_MONITOR_QUEUE_OLDEST_MINUTES=30
MADDRAXIKON_MONITOR_CONSECUTIVE_FAILURE_LIMIT=3
MADDRAXIKON_CORRECTION_AUDIT_RETENTION_DAYS=3650
