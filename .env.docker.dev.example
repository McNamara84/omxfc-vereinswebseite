# Lokale Docker-Compose-Entwicklung
DOCKER_DEV_APP_ENV=local
DOCKER_DEV_APP_DEBUG=true
DOCKER_DEV_APP_KEY=base64:CHANGE_ME
DOCKER_DEV_APP_URL=http://localhost:8080
DOCKER_DEV_ASSET_URL=http://localhost:8080
DOCKER_DEV_APP_PORT=8080

# Vite / HMR
DOCKER_DEV_VITE_PORT=5173
DOCKER_DEV_VITE_HMR_HOST=localhost
DOCKER_DEV_VITE_DEV_SERVER_URL=http://localhost:5173
DOCKER_DEV_VITE_USE_POLLING=1
DOCKER_DEV_VITE_POLLING_INTERVAL=300
DOCKER_DEV_CHOKIDAR_USEPOLLING=1

# Datenbank / Suche
DOCKER_DEV_DB_DATABASE=omxfc_dev
DOCKER_DEV_DB_USERNAME=omxfc
DOCKER_DEV_DB_PASSWORD=omxfc
DOCKER_DEV_DB_FORWARD_PORT=3307
DOCKER_DEV_MYSQL_ROOT_PASSWORD=omxfc-root
DOCKER_DEV_TYPESENSE_API_KEY=local-dev-typesense-key
DOCKER_DEV_TYPESENSE_FORWARD_PORT=8108

# Laravel Runtime
DOCKER_DEV_CACHE_STORE=database
DOCKER_DEV_SESSION_DRIVER=database
DOCKER_DEV_QUEUE_CONNECTION=database
DOCKER_DEV_DB_QUEUE_RETRY_AFTER=420
DOCKER_DEV_SCOUT_DRIVER=typesense
DOCKER_DEV_SCOUT_QUEUE=true
DOCKER_DEV_TRUSTED_PROXIES=*
DOCKER_DEV_MAIL_MAILER=log
DOCKER_DEV_AUTO_MIGRATE=1

# Optionale externe Test- / Sandbox-Credentials
# Niemals echte Werte committen. Diese Datei nur lokal als .env.docker.dev.local nutzen.
E2E_SANDBOX_BASE_URL=
E2E_SANDBOX_USERNAME=
E2E_SANDBOX_PASSWORD=
E2E_SANDBOX_API_TOKEN=

# Optionaler isolierter Playwright-PHP-Port
DOCKER_DEV_PLAYWRIGHT_PORT=8001
# Maddraxikon OAuth/Baxx integration (disabled by default)
DOCKER_DEV_MADDRAXIKON_BASE_URL=https://de.maddraxikon.com
DOCKER_DEV_MADDRAXIKON_WIKI_KEY=maddraxikon-de
DOCKER_DEV_MADDRAXIKON_CONSENT_VERSION=2026-07-18
DOCKER_DEV_MADDRAXIKON_IDENTITY_HMAC_PEPPERS=
DOCKER_DEV_MADDRAXIKON_OAUTH_CLIENT_ID=
DOCKER_DEV_MADDRAXIKON_OAUTH_CLIENT_SECRET=
DOCKER_DEV_MADDRAXIKON_OAUTH_REDIRECT_URI=
DOCKER_DEV_MADDRAXIKON_OAUTH_SCOPE=mwoauth-authonly
DOCKER_DEV_MADDRAXIKON_LINKING_ENABLED=false
DOCKER_DEV_MADDRAXIKON_SYNC_ENABLED=false
DOCKER_DEV_MADDRAXIKON_AWARDS_ENABLED=false
DOCKER_DEV_MADDRAXIKON_USER_AGENT="OMXFC-Vereinswebsite/1.0 (https://maddrax-fanclub.de; info@maddraxikon.com)"
DOCKER_DEV_MADDRAXIKON_HTTP_CONNECT_TIMEOUT=5
DOCKER_DEV_MADDRAXIKON_HTTP_TIMEOUT=15
DOCKER_DEV_MADDRAXIKON_HTTP_ATTEMPTS=3
DOCKER_DEV_MADDRAXIKON_HTTP_RETRY_DELAY_MS=500
DOCKER_DEV_MADDRAXIKON_HTTP_RETRY_MAX_DELAY_MS=5000
DOCKER_DEV_MADDRAXIKON_API_MAXLAG=5
DOCKER_DEV_MADDRAXIKON_RECENT_CHANGES_RETENTION_DAYS=30
DOCKER_DEV_MADDRAXIKON_SYNC_MAX_WINDOW_MINUTES=360
DOCKER_DEV_MADDRAXIKON_RECOVERY_MAX_WINDOW_DAYS=90
DOCKER_DEV_MADDRAXIKON_USERCONTRIBS_BATCH_SIZE=50
DOCKER_DEV_MADDRAXIKON_EVALUATION_SOURCE_BATCH_SIZE=100
DOCKER_DEV_MADDRAXIKON_EVALUATION_API_BATCH_SIZE=50
DOCKER_DEV_MADDRAXIKON_MONITOR_PENDING_STALE_HOURS=26
DOCKER_DEV_MADDRAXIKON_MONITOR_IMPORT_STALE_MINUTES=60
DOCKER_DEV_MADDRAXIKON_MONITOR_SCHEDULER_STALE_MINUTES=5
DOCKER_DEV_MADDRAXIKON_MONITOR_QUEUE_BACKLOG_LIMIT=100
DOCKER_DEV_MADDRAXIKON_MONITOR_QUEUE_OLDEST_MINUTES=30
DOCKER_DEV_MADDRAXIKON_MONITOR_CONSECUTIVE_FAILURE_LIMIT=3
DOCKER_DEV_MADDRAXIKON_CORRECTION_AUDIT_RETENTION_DAYS=3650
